FROM python:3.11-slim

WORKDIR /app

COPY packages/poker-engine /app/packages/poker-engine
COPY apps/api /app/api
COPY ai /app/ai

RUN pip install --no-cache-dir \
    -e /app/packages/poker-engine \
    -e /app/api

WORKDIR /app/api

EXPOSE 8000

CMD uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}
